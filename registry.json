    { "name": "snow-ice",        "module": "src/snow-ice.glsl.js",        "prefix": "snowIce",        "tags": ["winter", "surface"] },
    { "name": "lightning",       "module": "src/lightning.glsl.js",       "prefix": "lightning",      "tags": ["fx", "additive"] },
    { "name": "flame",           "module": "src/flame.glsl.js",           "prefix": "flame",          "tags": ["fx", "fire", "additive"] },
