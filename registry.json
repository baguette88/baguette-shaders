    { "name": "oil-slick",       "module": "src/oil-slick.glsl.js",       "prefix": "oilSlick",       "tags": ["material", "iridescent"] },
    { "name": "sand-dunes",      "module": "src/sand-dunes.glsl.js",      "prefix": "sandDunes",      "tags": ["terrain", "surface"] }
